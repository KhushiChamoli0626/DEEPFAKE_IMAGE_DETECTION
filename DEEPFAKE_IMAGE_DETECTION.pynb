1b[0m\u001b[0m_call_impl\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m*\u001b[0m\u001b[0margs\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m**\u001b[0m\u001b[0mkwargs\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m   1777\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m   1778\u001b[0m     \u001b[0;31m# torchrec tests the code consistency with the following code\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/torch/nn/modules/module.py\u001b[0m in \u001b[0;36m_call_impl\u001b[0;34m(self, *args, **kwargs)\u001b[0m\n\u001b[1;32m   1785\u001b[0m                 \u001b[0;32mor\u001b[0m \u001b[0m_global_backward_pre_hooks\u001b[0m \u001b[0;32mor\u001b[0m \u001b[0m_global_backward_hooks\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m   1786\u001b[0m                 or _global_forward_hooks or _global_forward_pre_hooks):\n\u001b[0;32m-> 1787\u001b[0;31m             \u001b[0;32mreturn\u001b[0m \u001b[0mforward_call\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0;34m*\u001b[0m\u001b[0margs\u001b[0m\u001b[0;34m,\u001b[0m \u001b[0;34m**\u001b[0m\u001b[0mkwargs\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m   1788\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m   1789\u001b[0m         \u001b[0mresult\u001b[0m \u001b[0;34m=\u001b[0m \u001b[0;32mNone\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/torch/nn/modules/conv.py\u001b[0m in \u001b[0;36mforward\u001b[0;34m(self, input, output_size)\u001b[0m\n\u001b[1;32m   1182\u001b[0m         )\n\u001b[1;32m   1183\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m-> 1184\u001b[0;31m         return F.conv_transpose2d(\n\u001b[0m\u001b[1;32m   1185\u001b[0m             \u001b[0minput\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m   1186\u001b[0m             \u001b[0mself\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mweight\u001b[0m\u001b[0;34m,\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mKeyboardInterrupt\u001b[0m: "]}],"source":["correct = 0\n","total = 0\n","\n","D.eval()\n","\n","with torch.no_grad():\n","    for real, _ in dataloader:\n","        real = real.to(device)\n","        batch_size = real.size(0)\n","\n","        # Real labels\n","        output_real = D(real)\n","        preds_real = torch.sigmoid(output_real) > 0.5\n","        correct += preds_real.sum().item()\n","        total += batch_size\n","\n","        # Fake images\n","        z = torch.randn(batch_size, 100, 1, 1).to(device)\n","        fake = G(z)\n","\n","        output_fake = D(fake)\n","        preds_fake = torch.sigmoid(output_fake) < 0.5\n","        correct += preds_fake.sum().item()\n","        total += batch_size\n","\n","accuracy = 100 * correct / total\n","print(f\"Detection Accuracy: {accuracy:.2f}%\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"kqaEfnUP2D0m"},"outputs":[],"source":["#GRAD-CAM\n","\n","import torch.nn.functional as F\n","\n","class GradCAM:\n","    def __init__(self, model):\n","        self.model = model\n","        self.gradients = None\n","        self.activations = None\n","\n","        # Hook last conv layer\n","        for name, module in model.named_modules():\n","            if isinstance(module, torch.nn.Conv2d):\n","                module.register_forward_hook(self.save_activation)\n","                module.register_backward_hook(self.save_gradient)\n","\n","    def save_activation(self, module, input, output):\n","        self.activations = output\n","    def save_gradient(self, module, grad_input, grad_output):\n","        self.gradients = grad_output[0]\n","    def generate(self, input_image):\n","        self.model.zero_grad()\n","        output = self.model(input_image)\n","        loss = output.mean()\n","        loss.backward()\n","        weights = self.gradients.mean(dim=(2,3), keepdim=True)\n","        cam = (weights * self.activations).sum(dim=1)\n","        cam = F.relu(cam)\n","        cam = cam.squeeze().cpu().detach().numpy()\n","        return cam"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":487},"executionInfo":{"elapsed":200,"status":"ok","timestamp":1777555670298,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"1-2MIJ9L2h5t","outputId":"c60e2349-2eeb-4a3c-9c44-4c0ca626064e"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#GRAD-CAM VISUALIZATION\n","\n","import torch.nn.functional as F\n","\n","class GradCAM:\n","    def __init__(self, model):\n","        self.model = model\n","        self.gradients = None\n","        self.activations = None\n","\n","        # Hook last conv layer\n","        for name, module in model.named_modules():\n","            if isinstance(module, torch.nn.Conv2d):\n","                module.register_forward_hook(self.save_activation)\n","                module.register_backward_hook(self.save_gradient)\n","\n","    def save_activation(self, module, input, output):\n","        self.activations = output\n","    def save_gradient(self, module, grad_input, grad_output):\n","        self.gradients = grad_output[0]\n","    def generate(self, input_image):\n","        self.model.zero_grad()\n","        output = self.model(input_image)\n","        loss = output.mean()\n","        loss.backward()\n","        weights = self.gradients.mean(dim=(2,3), keepdim=True)\n","        cam = (weights * self.activations).sum(dim=1)\n","        cam = F.relu(cam)\n","        cam = cam.squeeze().cpu().detach().numpy()\n","        return cam"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":521},"executionInfo":{"elapsed":1399,"status":"ok","timestamp":1777555675330,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"nEe1H2KC4dNG","outputId":"5665ffdd-f070-4ef4-d899-a5ce1c5a1bf0"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#FAKE GENERATED IMAGES\n","\n","import torchvision\n","import matplotlib.pyplot as plt\n","\n","G.eval()\n","\n","with torch.no_grad():\n","    z = torch.randn(16, 100, 1, 1).to(device)\n","    fake_images = G(z).cpu()\n","\n","# Create grid (no resizing = less blur)\n","grid = torchvision.utils.make_grid(fake_images, nrow=4, normalize=True)\n","\n","plt.figure(figsize=(6,6))\n","\n","plt.imshow(grid.permute(1, 2, 0))\n","plt.axis(\"off\")\n","plt.title(\"Generated Images\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":521},"executionInfo":{"elapsed":1670,"status":"ok","timestamp":1777555680696,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"_uDjDkAj4f05","outputId":"5d113b62-c040-49c7-d617-5167558047eb"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 600x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#REAL IMAGES\n","\n","real_batch, _ = next(iter(dataloader))\n","real_batch = real_batch[:16]\n","grid_real = torchvision.utils.make_grid(real_batch, nrow=4, normalize=True)\n","plt.figure(figsize=(6,6))\n","plt.imshow(grid_real.permute(1, 2, 0))\n","plt.axis(\"off\")\n","plt.title(\"Real Images\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"N8r99skrsR73"},"outputs":[],"source":["#PREDICTION FUNCTION (REAL V/S FAKE)\n","\n","import torch\n","\n","def predict_image(model, image, device):\n","    model.eval()\n","\n","    with torch.no_grad():\n","        image = image.unsqueeze(0).to(device)  # add batch dim\n","        output = model(image)\n","\n","        prob = torch.sigmoid(output)  # convert to probability\n","\n","        if prob.item() > 0.5:\n","            return \"Real\", prob.item()\n","        else:\n","            return \"Fake\", prob.item()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":856},"executionInfo":{"elapsed":505,"status":"ok","timestamp":1777555687700,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"vY1Bai9EsauB","outputId":"f3111b33-9863-4055-bd14-47d25bebcbe8"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stderr","text":["WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [-0.99215686..0.9372549].\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#TEST ON IMAGES\n","\n","img = real_img.permute(1,2,0).cpu()\n","\n","# Denormalize\n","img = (img * 0.5) + 0.5   # [-1,1] → [0,1]\n","\n","plt.imshow(img)\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()\n","\n","import matplotlib.pyplot as plt\n","\n","real_img, _ = next(iter(dataloader))\n","real_img = real_img[0]\n","\n","label, prob = predict_image(D, real_img, device)\n","\n","plt.imshow(real_img.permute(1,2,0).cpu())\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()\n","\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":428},"executionInfo":{"elapsed":162,"status":"ok","timestamp":1777555695923,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"5kOzYQAxu0gt","outputId":"1fa524ad-142a-4703-cf41-bb7cca39baa7"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["real_img, _ = next(iter(dataloader))\n","real_img = real_img[0]\n","\n","label, prob = predict_image(D, real_img, device)\n","\n","img = real_img.permute(1,2,0).cpu()\n","img = (img * 0.5) + 0.5   # denormalize\n","img = img.clamp(0,1)\n","\n","plt.imshow(img)\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"mKUI41XssvTL"},"outputs":[],"source":["#GRAD-CAM (FOR EXPLANABILITY)\n","\n","import torch.nn.functional as F\n","\n","class GradCAM:\n","    def __init__(self, model):\n","        self.model = model\n","        self.gradients = None\n","        self.activations = None\n","\n","        # Hook last conv layer\n","        for name, module in model.named_modules():\n","            if isinstance(module, torch.nn.Conv2d):\n","                module.register_forward_hook(self.save_activation)\n","                module.register_backward_hook(self.save_gradient)\n","\n","    def save_activation(self, module, input, output):\n","        self.activations = output\n","    def save_gradient(self, module, grad_input, grad_output):\n","        self.gradients = grad_output[0]\n","    def generate(self, input_image):\n","        self.model.zero_grad()\n","        output = self.model(input_image)\n","        loss = output.mean()\n","        loss.backward()\n","        weights = self.gradients.mean(dim=(2,3), keepdim=True)\n","        cam = (weights * self.activations).sum(dim=1)\n","        cam = F.relu(cam)\n","        cam = cam.squeeze().cpu().detach().numpy()\n","        return cam"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":535},"executionInfo":{"elapsed":209,"status":"ok","timestamp":1777555703875,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"mDFpx9bPs2oI","outputId":"0de37b40-95a7-43d6-dc26-d6f2d9c6d275"},"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/torch/nn/modules/module.py:1867: FutureWarning: Using a non-full backward hook when the forward contains multiple autograd Nodes is deprecated and will be removed in future versions. This hook will be missing some grad_input. Please use register_full_backward_hook to get the documented behavior.\n","  self._maybe_warn_non_full_backward_hook(args, result, grad_fn)\n","/tmp/ipykernel_19084/975192951.py:13: RuntimeWarning: invalid value encountered in divide\n","  cam = (cam - cam.min()) / (cam.max() - cam.min())\n","WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [-0.9764706..0.9137255].\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#VISUALIZE GRAD-CAM\n","\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","gradcam = GradCAM(D)\n","\n","img = real_img.unsqueeze(0).to(device)\n","cam = gradcam.generate(img)\n","\n","cam = cv2.resize(cam, (64,64))\n","cam = (cam - cam.min()) / (cam.max() - cam.min())\n","\n","plt.imshow(real_img.permute(1,2,0).cpu())\n","plt.imshow(cam, cmap='jet', alpha=0.5)\n","plt.title(\"Grad-CAM\")\n","plt.axis(\"off\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"gdm5TRj_v3cr"},"outputs":[],"source":["#FREEZE GENERATOR\n","\n","for param in G.parameters():\n","    param.requires_grad = False"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":1031387,"status":"ok","timestamp":1777556740856,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"kcyp6xyWv-tN","outputId":"205de1db-4e19-49c4-ea40-e7dc87b154e5"},"outputs":[{"output_type":"stream","name":"stdout","text":["Epoch 1 Loss: 0.6415\n","Epoch 2 Loss: 0.2963\n","Epoch 3 Loss: 0.0949\n","Epoch 4 Loss: 0.1014\n","Epoch 5 Loss: 0.0452\n"]}],"source":["#TRAIN ONLY DISCRIMINATOR\n","\n","optimizer_D = torch.optim.Adam(D.parameters(), lr=0.0001)\n","criterion = nn.BCEWithLogitsLoss()\n","\n","num_epochs = 5   # KEEP SMALL FOR SPEED\n","\n","D.train()\n","for epoch in range(num_epochs):\n","    for i, (real, _) in enumerate(dataloader):\n","        real = real.to(device)\n","        batch_size = real.size(0)\n","        real_labels = torch.ones((batch_size,1), device=device)\n","        fake_labels = torch.zeros((batch_size,1), device=device)\n","        # GENERATE FAKE ONCE (no grad = faster)\n","        # HARD FAKE (replace GAN fake)\n","        fake = real + 0.05 * torch.randn_like(real)\n","        fake = torch.clamp(fake, -1, 1)\n","        # COMBINE\n","        inputs = torch.cat([real, fake], dim=0)\n","        labels = torch.cat([real_labels, fake_labels], dim=0)\n","        optimizer_D.zero_grad()\n","        outputs = D(inputs)\n","        loss = criterion(outputs, labels)\n","        loss.backward()\n","        optimizer_D.step()\n","        # SPEED BREAK (VERY IMPORTANT)\n","        if i > 100:   # only 100 batches per epoch\n","            break\n","    print(f\"Epoch {epoch+1} Loss: {loss.item():.4f}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":856},"executionInfo":{"elapsed":239,"status":"ok","timestamp":1777556771134,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"ilyTnCscwnym","outputId":"6d1ce3c8-1a64-45d4-b85e-e42b2af37aae"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stderr","text":["WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [-0.99215686..0.9529412].\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["#TEST ON IMAGES\n","\n","img = real_img.permute(1,2,0).cpu()\n","\n","# Denormalize\n","img = (img * 0.5) + 0.5   # [-1,1] → [0,1]\n","\n","plt.imshow(img)\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()\n","\n","import matplotlib.pyplot as plt\n","\n","real_img, _ = next(iter(dataloader))\n","real_img = real_img[0]\n","\n","label, prob = predict_image(D, real_img, device)\n","\n","plt.imshow(real_img.permute(1,2,0).cpu())\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"kHLeeIMoxecB"},"outputs":[],"source":["#CREATE TRAIN/TEST SPLIT\n","\n","from torch.utils.data import random_split\n","\n","train_size = int(0.8 * len(dataset))\n","test_size = len(dataset) - train_size\n","\n","train_dataset, test_dataset = random_split(dataset, [train_size, test_size])"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"JmU7CBFFxiZA"},"outputs":[],"source":["#SEPERATE DATA LOADERS\n","\n","train_loader = DataLoader(train_dataset, batch_size=64, shuffle=True)\n","test_loader = DataLoader(test_dataset, batch_size=64, shuffle=False)"]},{"cell_type":"code","source":[],"metadata":{"id":"0IfD5dQ9x5b1"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":147949,"status":"ok","timestamp":1777557123013,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"hciCM8b2yL_U","outputId":"ebe735b7-b284-4081-bbf1-74054b1e7e47"},"outputs":[{"output_type":"stream","name":"stdout","text":["Test Accuracy: 85.73%\n"]}],"source":["#EVALUATING ON TEST LOADER\n","\n","correct = 0\n","total = 0\n","\n","D.eval()\n","\n","with torch.no_grad():\n","    for real, _ in test_loader:\n","\n","        real = real.to(device)\n","        batch_size = real.size(0)\n","\n","        # Real\n","        preds_real = (torch.sigmoid(D(real)) > 0.5).float()\n","\n","        # Fake\n","        #ACCURACY CALCULATION\n","\n","correct = 0\n","total = 0\n","\n","D.eval()\n","\n","with torch.no_grad():\n","    for i, (real, _) in enumerate(dataloader):\n","\n","        real = real.to(device)\n","        batch_size = real.size(0)\n","\n","        #  Real predictions\n","        output_real = torch.sigmoid(D(real))\n","        preds_real = (output_real > 0.5).float()\n","        correct += preds_real.sum().item()\n","        total += batch_size\n","\n","        #  Fake predictions (only once per batch)\n","        #  HARD FAKE HERE ALSO\n","        fake = real + 0.05 * torch.randn_like(real)\n","        fake = torch.clamp(fake, -1, 1)\n","        output_fake = torch.sigmoid(D(fake))\n","        preds_fake = (output_fake < 0.5).float()\n","        correct += preds_fake.sum().item()\n","        total += batch_size\n","\n","        #  SPEED CONTROL (VERY IMPORTANT)\n","        if i > 100:   # only 100 batches\n","            break\n","            accuracy = 100 * correct / total\n","            print(f\"Accuracy: {accuracy:.2f}%\")\n","            preds_fake = (torch.sigmoid(D(fake)) < 0.5).float()\n","\n","        correct += preds_real.sum().item()\n","        correct += preds_fake.sum().item()\n","        total += 2 * batch_size\n","\n","accuracy = 100 * correct / total\n","print(f\"Test Accuracy: {accuracy:.2f}%\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":137,"status":"ok","timestamp":1777491271434,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"uT5Cnmwny5Hg","outputId":"ffea7f35-dc04-4b8b-f71d-c98b8f20ba28"},"outputs":[{"name":"stdout","output_type":"stream","text":["Real scores (first 10): tensor([0.9995, 1.0000, 0.6341, 0.9294, 1.0000, 0.9999, 1.0000, 1.0000, 0.9999,\n","        1.0000], device='cuda:0')\n","Fake scores (first 10): tensor([5.7042e-14, 6.2660e-16, 3.8651e-16, 1.1202e-09, 2.1407e-16, 3.0173e-10,\n","        8.4044e-17, 1.0005e-17, 1.7924e-18, 6.2292e-12], device='cuda:0')\n"]}],"source":["with torch.no_grad():\n","    real, _ = next(iter(test_loader))\n","    real = real.to(device)\n","\n","    z = torch.randn(real.size(0), 100, 1, 1, device=device)\n","    fake = G(z)\n","\n","    real_scores = torch.sigmoid(D(real))\n","    fake_scores = torch.sigmoid(D(fake))\n","\n","    print(\"Real scores (first 10):\", real_scores[:10].view(-1))\n","    print(\"Fake scores (first 10):\", fake_scores[:10].view(-1))"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":66860,"status":"ok","timestamp":1777557829423,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"RNoRyaIpzyWC","outputId":"9fe75db0-21c0-42ec-a83a-00d001ac74c7"},"outputs":[{"output_type":"stream","name":"stdout","text":["Accuracy: 86.04%\n"]}],"source":["#ACCURACY CALCULATION\n","\n","correct = 0\n","total = 0\n","\n","D.eval()\n","\n","with torch.no_grad():\n","    for i, (real, _) in enumerate(dataloader):\n","\n","        real = real.to(device)\n","        batch_size = real.size(0)\n","\n","        # 🔥 Real predictions\n","        output_real = torch.sigmoid(D(real))\n","        preds_real = (output_real > 0.5).float()\n","        correct += preds_real.sum().item()\n","        total += batch_size\n","\n","        # 🔥 Fake predictions (only once per batch)\n","        # 🔥 HARD FAKE HERE ALSO\n","        fake = real + 0.05 * torch.randn_like(real)\n","        fake = torch.clamp(fake, -1, 1)\n","\n","        output_fake = torch.sigmoid(D(fake))\n","        preds_fake = (output_fake < 0.5).float()\n","        correct += preds_fake.sum().item()\n","        total += batch_size\n","\n","        # ⚡ SPEED CONTROL (VERY IMPORTANT)\n","        if i > 100:   # only 100 batches\n","            break\n","\n","accuracy = 100 * correct / total\n","print(f\"Accuracy: {accuracy:.2f}%\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"lLZYOBc-4o4E"},"outputs":[],"source":["import torchvision.transforms.functional as TF\n","\n","rand = torch.rand(1).item()\n","\n","if rand < 0.33:\n","    fake = real + 0.05 * torch.randn_like(real)\n","\n","elif rand < 0.66:\n","    fake = TF.gaussian_blur(real, kernel_size=5)\n","\n","else:\n","    fake = real.clone()\n","    fake[:, :, 16:48, 16:48] = 0   # occlusion attack\n","\n","fake = torch.clamp(fake, -1, 1)"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":521},"executionInfo":{"elapsed":357,"status":"ok","timestamp":1777491292317,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"VR2ZCqTk4v5P","outputId":"0e913e13-002c-4995-b9c4-c792df3fbc64"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 600x600 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["#FAKE GENERATED IMAGES\n","\n","import torchvision\n","import matplotlib.pyplot as plt\n","\n","G.eval()\n","\n","with torch.no_grad():\n","    z = torch.randn(16, 100, 1, 1).to(device)\n","    fake_images = G(z).cpu()\n","\n","# Create grid (no resizing = less blur)\n","grid = torchvision.utils.make_grid(fake_images, nrow=4, normalize=True)\n","\n","plt.figure(figsize=(6,6))\n","\n","plt.imshow(grid.permute(1, 2, 0))\n","plt.axis(\"off\")\n","plt.title(\"Generated Images\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":521},"executionInfo":{"elapsed":567,"status":"ok","timestamp":1777491296320,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"yu6MwJhK41nP","outputId":"2f2f3e4f-8025-4ad6-bf2d-758566fb7644"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 600x600 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["#REAL IMAGES\n","\n","real_batch, _ = next(iter(dataloader))\n","real_batch = real_batch[:16]\n","grid_real = torchvision.utils.make_grid(real_batch, nrow=4, normalize=True)\n","plt.figure(figsize=(6,6))\n","plt.imshow(grid_real.permute(1, 2, 0))\n","plt.axis(\"off\")\n","plt.title(\"Real Images\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":856},"executionInfo":{"elapsed":280,"status":"ok","timestamp":1777491299346,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"lZBtyMT05Arj","outputId":"d2867189-d8b7-45a9-d3b5-66c96bde6765"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 640x480 with 1 Axes>"]},"metadata":{},"output_type":"display_data"},{"name":"stderr","output_type":"stream","text":["WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [-0.88235295..0.99215686].\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 640x480 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["#TEST ON IMAGES\n","\n","img = real_img.permute(1,2,0).cpu()\n","\n","# Denormalize\n","img = (img * 0.5) + 0.5   # [-1,1] → [0,1]\n","\n","plt.imshow(img)\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()\n","\n","import matplotlib.pyplot as plt\n","\n","real_img, _ = next(iter(dataloader))\n","real_img = real_img[0]\n","\n","label, prob = predict_image(D, real_img, device)\n","\n","plt.imshow(real_img.permute(1,2,0).cpu())\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":428},"executionInfo":{"elapsed":138,"status":"ok","timestamp":1777491303298,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"Mle5zSay5KVj","outputId":"bafb8c2c-b56b-4d56-8d6f-ca567c3bffab"},"outputs":[{"data":{"image/png":"\n","text/plain":["<Figure size 640x480 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["real_img, _ = next(iter(dataloader))\n","real_img = real_img[0]\n","\n","label, prob = predict_image(D, real_img, device)\n","\n","img = real_img.permute(1,2,0).cpu()\n","img = (img * 0.5) + 0.5   # denormalize\n","img = img.clamp(0,1)\n","\n","plt.imshow(img)\n","plt.title(f\"{label} ({prob:.2f})\")\n","plt.axis(\"off\")\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":480},"executionInfo":{"elapsed":77,"status":"ok","timestamp":1777491305917,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"},"user_tz":-330},"id":"JuSHiVJy5WKq","outputId":"05707bd6-e0cf-433f-9efb-6afe20725b5c"},"outputs":[{"name":"stderr","output_type":"stream","text":["/tmp/ipykernel_4898/975192951.py:13: RuntimeWarning: invalid value encountered in divide\n","  cam = (cam - cam.min()) / (cam.max() - cam.min())\n","WARNING:matplotlib.image:Clipping input data to the valid range for imshow with RGB data ([0..1] for floats or [0..255] for integers). Got range [-1.0..0.9843137].\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 640x480 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["#VISUALIZE GRAD-CAM\n","\n","import cv2\n","import numpy as np\n","import matplotlib.pyplot as plt\n","\n","gradcam = GradCAM(D)\n","\n","img = real_img.unsqueeze(0).to(device)\n","cam = gradcam.generate(img)\n","\n","cam = cv2.resize(cam, (64,64))\n","cam = (cam - cam.min()) / (cam.max() - cam.min())\n","\n","plt.imshow(real_img.permute(1,2,0).cpu())\n","plt.imshow(cam, cmap='jet', alpha=0.5)\n","plt.title(\"Grad-CAM\")\n","plt.axis(\"off\")\n","plt.show()"]},{"cell_type":"code","source":["#ACCURACY CALCULATION\n","\n","correct = 0\n","total = 0\n","\n","D.eval()\n","\n","with torch.no_grad():\n","    for real, _ in test_loader:\n","        real = real.to(device)\n","        batch_size = real.size(0)\n","\n","        # Real predictions\n","        output_real = torch.sigmoid(D(real))\n","        preds_real = (output_real > 0.5).float()\n","        correct += preds_real.sum().item()\n","        total += batch_size\n","\n","        # Fake predictions\n","        fake = real + 0.05 * torch.randn_like(real)\n","        fake = torch.clamp(fake, -1, 1)\n","        output_fake = torch.sigmoid(D(fake))\n","        preds_fake = (output_fake < 0.5).float()\n","        correct += preds_fake.sum().item()\n","        total += batch_size\n","\n","accuracy = 100 * correct / total\n","print(f\"Test Accuracy: {accuracy:.2f}%\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"XYAFjJumAwsG","executionInfo":{"status":"ok","timestamp":1777563176927,"user_tz":-330,"elapsed":161413,"user":{"displayName":"Khushi Chamoli","userId":"00982718732420979706"}},"outputId":"0a42ff30-0241-4810-edbd-6d2fdbe750d9"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Test Accuracy: 87.63%\n"]}]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"T4","provenance":[],"authorship_tag":"ABX9TyMHpos6nLoQr7zV+KNUJLOK"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}